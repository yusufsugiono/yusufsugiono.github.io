      <article class="section__contact_me" id="section__contact_me">
        <h2>CONTACT ME</h2>
        <form action="#" name="contact_me" novalidate>
          <label for="email">Email <span class="required">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="off"
            placeholder="your@email.com"
          />
          <div class="form-error email-error">&nbsp;</div>

          <label for="whatsapp">WhatsApp</label>
          <input
            type="tel"
            id="whatsapp"
            name="whatsapp"
            autocomplete="off"
            placeholder="+62 8123456789"
            pattern="^(?:\\+|0)[0-9]+$"
          />
          <div class="form-error whatsapp-error">&nbsp;</div>

          <label for="sender_name"
            >Full Name <span class="required">*</span></label
          >
          <input
            type="text"
            id="sender_name"
            name="sender_name"
            autocomplete="off"
            placeholder="Your name"
          />
          <div class="form-error sender_name-error">&nbsp;</div>

          <label for="message">Message <span class="required">*</span></label>
          <textarea
            name="message"
            id="message"
            rows="7"
            placeholder="Type your message here..."></textarea>
          <div class="form-error message-error">&nbsp;</div>

          <button type="submit">
            <i class="fa-solid fa-paper-plane"></i> Send
          </button>
        </form>
      </article>
