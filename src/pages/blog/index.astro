---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

// Tampilkan draft hanya di dev mode
const allPosts = await getCollection('blog', ({ data }) => import.meta.env.DEV ? true : !data.draft);

// Urutkan dari yang terbaru
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 1. Ekstrak daftar kategori unik beserta jumlah artikelnya
const categoryCounts = sortedPosts.reduce((acc, post) => {
  const cat = post.data.category || 'Umum';
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categories = Object.keys(categoryCounts).sort();

// 2. Ekstrak daftar arsip bulanan (Tahun-Bulan) beserta jumlah artikelnya
const archiveGroups = sortedPosts.reduce((acc, post) => {
  const date = new Date(post.data.pubDate);
  const year = date.getFullYear();
  const month = date.getMonth(); // 0-11
  
  // Format nama bulan untuk tampilan (e.g., "May 2026")
  const monthName = date.toLocaleDateString('en-US', { month: 'short' });
  const label = `${monthName} ${year}`;
  
  // Key format "2026-05" untuk filter nilai
  const key = `${year}-${String(month + 1).padStart(2, '0')}`;
  
  if (!acc[key]) {
    acc[key] = { label, count: 0 };
  }
  acc[key].count += 1;
  return acc;
}, {} as Record<string, { label: string; count: number }>);

const sortedArchives = Object.keys(archiveGroups)
  .sort((a, b) => b.localeCompare(a)) // Urutkan tanggal terbaru ke terlama
  .map(key => ({
    key,
    label: archiveGroups[key].label,
    count: archiveGroups[key].count,
  }));
---

<BaseLayout title="Blogs | Yusuf Sugiono" bodyClass="full-width">
  <main>
    <nav class="blog-top-nav">
      <a href="/" class="brand-name">Yusuf Sugiono</a>
      <ul>
        <li><a href="/#section__portfolio">PORTFOLIO</a></li>
        <li><a href="/blog">BLOG</a></li>
        <li><a href="/#section__contact_me">CONTACT</a></li>
      </ul>
    </nav>
    <article class="blog-archive-container">
      <h1 class="archive-main-title">Blogs</h1>
      
      <!-- Tombol Bersihkan Filter (Tersembunyi secara default) -->
      <div id="clear-filter-wrapper" style="display: none; margin-bottom: 20px;">
        <button id="clear-filter-btn" class="clear-btn">
          <i class="fa-solid fa-xmark"></i> Clear Filter (<span id="active-filter-text"></span>)
        </button>
      </div>

      <div class="blog-layout">
        <!-- Kolom Kiri: Daftar Artikel -->
        <div class="blog-main-list">
          {sortedPosts.length === 0 ? (
            <p class="no-posts">Belum ada artikel yang dipublikasikan.</p>
          ) : (
            sortedPosts.map((post) => {
              const { title, description, pubDate, image, imageAlt, category } = post.data;
              
              // Format ISO Bulan-Tahun untuk filter data-archive (format: 2026-05)
              const dateObj = new Date(pubDate);
              const archiveKey = `${dateObj.getFullYear()}-${String(dateObj.getMonth() + 1).padStart(2, '0')}`;
              
              const formattedDate = dateObj.toLocaleDateString('id-ID', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              });

              return (
                <div 
                  class="blog-post-card" 
                  data-category={category} 
                  data-archive={archiveKey}
                >
                  <a href={`/blog/${post.id}`} class="card-link">
                    <img src={image} alt={imageAlt} class="card-image" />
                    <div class="card-content">
                      <div class="card-header-meta">
                        <span class="card-category">{category}</span>
                        <span class="card-dot">•</span>
                        <span class="card-date">{formattedDate}</span>
                      </div>
                      <h3>{title}</h3>
                      <p class="card-description">{description}</p>
                      <span class="view-more-text">View more..</span>
                    </div>
                  </a>
                </div>
              );
            })
          )}
        </div>

        <!-- Kolom Kanan: Sidebar Widget -->
        <div class="blog-sidebar">
          <!-- Widget Kategori -->
          <div class="sidebar-widget">
            <h3>Category</h3>
            <ul>
              {categories.map((cat) => (
                <li>
                  <a href={`/blog?category=${cat}`} class="filter-category-btn" data-category={cat}>
                    <span>{cat}</span>
                    <span class="count">({categoryCounts[cat]})</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Widget Arsip Bulanan -->
          <div class="sidebar-widget">
            <h3>Published</h3>
            <ul>
              {sortedArchives.map((archive) => (
                <li>
                  <a href={`/blog?archive=${archive.key}`} class="filter-archive-btn" data-archive={archive.key}>
                    <span>{archive.label}</span>
                    <span class="count">({archive.count})</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<!-- Client-side Logic untuk Filtering Interaktif -->
<script>
  function applyFilters() {
    const params = new URLSearchParams(window.location.search);
    const categoryFilter = params.get('category');
    const archiveFilter = params.get('archive');
    
    const articles = document.querySelectorAll('.blog-post-card');
    let visibleCount = 0;

    articles.forEach(article => {
      const artCategory = article.getAttribute('data-category');
      const artArchive = article.getAttribute('data-archive');
      
      let show = true;
      if (categoryFilter && artCategory !== categoryFilter) {
        show = false;
      }
      if (archiveFilter && artArchive !== archiveFilter) {
        show = false;
      }
      
      if (show) {
        (article as HTMLElement).style.display = 'block';
        visibleCount++;
      } else {
        (article as HTMLElement).style.display = 'none';
      }
    });

    // Update active styling pada link sidebar
    document.querySelectorAll('.filter-category-btn').forEach(btn => {
      if (categoryFilter && btn.getAttribute('data-category') === categoryFilter) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    document.querySelectorAll('.filter-archive-btn').forEach(btn => {
      if (archiveFilter && btn.getAttribute('data-archive') === archiveFilter) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    // Tampilkan / sembunyikan tombol clear filter
    const clearBtnWrapper = document.getElementById('clear-filter-wrapper');
    const activeFilterText = document.getElementById('active-filter-text');
    if (clearBtnWrapper && activeFilterText) {
      if (categoryFilter || archiveFilter) {
        clearBtnWrapper.style.display = 'block';
        if (categoryFilter && archiveFilter) {
          activeFilterText.textContent = `${categoryFilter} & ${archiveFilter}`;
        } else {
          activeFilterText.textContent = categoryFilter || archiveFilter || '';
        }
      } else {
        clearBtnWrapper.style.display = 'none';
      }
    }
  }

  // Handle klik pada link filter secara client-side tanpa reload halaman penuh jika memungkinkan
  function initFilterListeners() {
    const filterLinks = document.querySelectorAll('.filter-category-btn, .filter-archive-btn');
    filterLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
        if (href) {
          const url = new URL(href, window.location.origin);
          window.history.pushState({}, '', url.toString());
          applyFilters();
        }
      });
    });

    document.getElementById('clear-filter-btn')?.addEventListener('click', () => {
      const url = new URL(window.location.href);
      url.search = '';
      window.history.pushState({}, '', url.toString());
      applyFilters();
    });
  }

  // Jalankan ketika DOM siap dan ketika navigasi history terjadi
  window.addEventListener('DOMContentLoaded', () => {
    applyFilters();
    initFilterListeners();
  });
  window.addEventListener('popstate', applyFilters);
</script>
