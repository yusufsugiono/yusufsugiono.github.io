---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

// 1. Definisikan static paths untuk generator build statis Astro
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV ? true : !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, description, pubDate, image, imageAlt, tags } = post.data;

// Render konten Markdown menjadi HTML component
const { Content } = await render(post);

// Tampilkan draft hanya di dev mode
const allPosts = await getCollection('blog', ({ data }) => import.meta.env.DEV ? true : !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Ekstrak data sidebar (Sama dengan halaman arsip agar konsisten)
const categoryCounts = sortedPosts.reduce((acc, post) => {
  const cat = post.data.category || 'Umum';
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const categories = Object.keys(categoryCounts).sort();

const archiveGroups = sortedPosts.reduce((acc, post) => {
  const date = new Date(post.data.pubDate);
  const year = date.getFullYear();
  const month = date.getMonth();
  const monthName = date.toLocaleDateString('en-US', { month: 'short' });
  const label = `${monthName} ${year}`;
  const key = `${year}-${String(month + 1).padStart(2, '0')}`;
  
  if (!acc[key]) {
    acc[key] = { label, count: 0 };
  }
  acc[key].count += 1;
  return acc;
}, {} as Record<string, { label: string; count: number }>);

const sortedArchives = Object.keys(archiveGroups)
  .sort((a, b) => b.localeCompare(a))
  .map(key => ({
    key,
    label: archiveGroups[key].label,
    count: archiveGroups[key].count,
  }));

const formattedDate = new Date(pubDate).toLocaleDateString('id-ID', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout title={`${title} | Yusuf Sugiono`} description={description} image={image} tags={tags} pubDate={pubDate.toISOString()} bodyClass="full-width">
  <main>
    <nav class="blog-top-nav">
      <a href="/" class="brand-name">Yusuf Sugiono</a>
      <ul>
        <li><a href="/#section__portfolio">PORTFOLIO</a></li>
        <li><a href="/blog">BLOG</a></li>
        <li><a href="/#section__contact_me">CONTACT</a></li>
      </ul>
    </nav>
    <article class="blog-detail-container">
      <div class="blog-layout">
        <!-- Kolom Kiri: Isi Artikel Lengkap -->
        <div class="blog-main-content">
          <div class="blog-detail-header">
            <h1 class="blog-detail-title">{title}</h1>
            <p class="blog-detail-date">{formattedDate}</p>
          </div>

          {image && (
            <div class="blog-featured-image-wrapper">
              <img src={image} alt={imageAlt} class="blog-featured-image" />
            </div>
          )}

          <!-- Tempat merender Markdown/MDX -->
          <div class="blog-content">
            <Content />
          </div>

          <div class="back-to-blog">
            <a href="/blog"><i class="fa-solid fa-arrow-left"></i> Back to Blogs</a>
          </div>
        </div>

        <!-- Kolom Kanan: Sidebar Widget -->
        <div class="blog-sidebar">
          <div class="sidebar-widget">
            <h3>Category</h3>
            <ul>
              {categories.map((cat) => (
                <li>
                  <a href={`/blog?category=${cat}`}>
                    <span>{cat}</span>
                    <span class="count">({categoryCounts[cat]})</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-widget">
            <h3>Published</h3>
            <ul>
              {sortedArchives.map((archive) => (
                <li>
                  <a href={`/blog?archive=${archive.key}`}>
                    <span>{archive.label}</span>
                    <span class="count">({archive.count})</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
