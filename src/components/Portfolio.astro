---
import PortfolioItem from "./PortfolioItem.astro";
import ArticleContainer from "./ArticleContainer.astro";
import ButtonViewMore from "./ButtonViewMore.astro";

import { portfolioSetupData } from "../utils/data.js";
const { title, data, seeMore } = portfolioSetupData;
---

<ArticleContainer className="section__portfolio" id="section__portfolio" title={title}>
  {
    data.map((item) => {
      const { title, description, link } = item;
      return (
        <PortfolioItem title={title} description={description} link={link} />
      );
    })
  }
  <ButtonViewMore text={seeMore.title} className="view-more" href={seeMore.link} />
</ArticleContainer>

