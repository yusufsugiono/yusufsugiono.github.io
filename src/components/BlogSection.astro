---
import { getCollection } from "astro:content";
import ArticleContainer from "./ArticleContainer.astro";
import ButtonViewMore from "./ButtonViewMore.astro";

// Tampilkan draft hanya di dev mode
const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.DEV ? true : data.draft !== true;
});

// Urutkan postingan berdasarkan tanggal terbaru
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Ambil maksimal 5 postingan teratas
const recentPosts = sortedPosts.slice(0, 5);

const sectionTitle = "BLOG POSTS";
---

<ArticleContainer
  className="section__blogpost"
  id="section__blogpost"
  title={sectionTitle}
>
  {
    recentPosts.map((post) => {
      const { title, description, pubDate, image, imageAlt } = post.data;

      // Format tanggal ke Bahasa Indonesia (Contoh: 7 Mei 2026)
      const formattedDate = new Date(pubDate).toLocaleDateString("id-ID", {
        day: "numeric",
        month: "long",
        year: "numeric",
      });

      return (
        <a href={`/blog/${post.id}`}>
          {image && <img src={image} alt={imageAlt} />}
          <div class="highlight__blogpost">
            <h3>{title}</h3>
            <p class="blog-date">{formattedDate}</p>
            <p>{description}</p>
          </div>
        </a>
      );
    })
  }

  {
    allPosts.length > 0 && (
      <ButtonViewMore
        text="SEE MORE ON MY BLOG"
        className="view-more"
        href="/blog"
      />
    )
  }
</ArticleContainer>

<style>
  .blog-date {
    font-size: 0.85rem;
    color: var(--secondary-color);
    margin-bottom: 8px;
    font-family: "Inter", sans-serif;
  }
</style>
